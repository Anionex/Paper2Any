# NVIDIA deployment profile example
#
# Copy to:
#   deploy/profiles/nv.env
# and only fill the values your machine needs.

DEPLOY_TARGET=nv

APP_HOST=0.0.0.0
APP_PORT=8000
APP_WORKERS=1
APP_CONDA_ENV=
APP_PYTHON=
APP_FALLBACK_PYTHON=
CONDA_SH=

FRONTEND_HOST=0.0.0.0
FRONTEND_PORT=3000
FRONTEND_DIR=
FRONTEND_NPM=
VITE_API_BASE_URL=

PAPER2ANY_PYTHON=
PAPER2ANY_ASSET_ROOT=
MODEL_SERVER_ENV_FILE=logs/model_servers.env

SAM3_ENABLED=1
SAM3_GPU_MODE=auto
GPU_QUERY_TOOL=nvidia-smi
SAM3_GPUS=
SAM3_INSTANCES_PER_GPU=1
SAM3_MAX_INSTANCES=2
SAM3_START_PORT=8021
SAM3_HOST=127.0.0.1
SAM3_STARTUP_STRATEGY=parallel
SAM3_STARTUP_STAGGER_SEC=0
SAM3_INSTANCE_HEALTH_TIMEOUT=360
SAM3_HOME=
SAM3_CHECKPOINT_PATH=
SAM3_BPE_PATH=

OCR_ENABLED=0
OCR_HOST=127.0.0.1
OCR_PORT=8003
OCR_WORKERS=1

MINERU_LOCAL_ENABLED=0
DRIPPER_AUTOSTOP=0
RMBG_MODEL_PATH=
